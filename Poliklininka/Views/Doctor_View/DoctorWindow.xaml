<Window x:Class="Poliklininka.Views.Doctor_View.DoctorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кабинет врача"
        Height="763"
        Width="966"
        WindowStartupLocation="CenterScreen"
        Background="#FFE5E5E5">

    <Grid Margin="15" Style="{StaticResource MainGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Кабинет врача"
                           Style="{StaticResource TitleText}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Left"/>

                <TextBlock Text="{Binding DoctorName, Mode=OneWay}"
                           Style="{StaticResource ValueText}"
                           FontSize="13"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <Button Content="Обновить"
                    Width="100"
                    Height="28"
                    DockPanel.Dock="Right"
                    Command="{Binding LoadAppointmentsCommand}"/>
        </DockPanel>

        <TabControl Grid.Row="1">

            <TabItem Header="Приемы">
                <Grid Margin="10" Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="590"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListView Grid.Column="0"
                              ItemsSource="{Binding Appointments}"
                              SelectedItem="{Binding SelectedAppointment, Mode=TwoWay}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID"
                                                DisplayMemberBinding="{Binding Id}"
                                                Width="45"/>

                                <GridViewColumn Header="Пациент"
                                                DisplayMemberBinding="{Binding Patient.Full_Name}"
                                                Width="170"/>

                                <GridViewColumn Header="Дата"
                                                DisplayMemberBinding="{Binding AppointmentDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="100"/>

                                <GridViewColumn Header="Время"
                                                DisplayMemberBinding="{Binding AppointmentDate, StringFormat={}{0:HH:mm}}"
                                                Width="80"/>

                                <GridViewColumn Header="Услуга"
                                                DisplayMemberBinding="{Binding MedService.ServiceName}"
                                                Width="120"/>

                                <GridViewColumn Header="Статус"
                                                DisplayMemberBinding="{Binding BookingStatus}"
                                                Width="90"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Grid.Column="1"
                            Style="{StaticResource VerticalSeparator}"
                            HorizontalAlignment="Center"
                            Height="620"
                            VerticalAlignment="Center"/>

                    <Grid Grid.Column="2" Margin="10,0,0,0">

                        <TextBlock Text="Данные приема"
                                   Style="{StaticResource TitleText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Пациент:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,50,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientName, Mode=OneWay}"
                                 Margin="140,45,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Дата:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,90,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedAppointmentDate, Mode=OneWay}"
                                 Margin="140,85,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Время:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,130,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedAppointmentTime, Mode=OneWay}"
                                 Margin="140,125,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Услуга:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,170,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedServiceName, Mode=OneWay}"
                                 Margin="140,165,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Статус:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,210,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedBookingStatus, Mode=OneWay}"
                                 Margin="140,205,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <Border Style="{StaticResource UnderlineBorder}"
                                Margin="10,250,10,0"
                                VerticalAlignment="Top"/>

                        <TextBlock Text="Пациент"
                                   Style="{StaticResource TitleText}"
                                   FontSize="14"
                                   HorizontalAlignment="Left"
                                   Margin="10,265,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBlock Text="Телефон:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,300,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientPhone, Mode=OneWay}"
                                 Margin="140,295,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Полис:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,340,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientPolicy, Mode=OneWay}"
                                 Margin="140,335,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Адрес:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,380,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientAddress, Mode=OneWay}"
                                 Margin="140,375,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Карточка пациента">
                <Grid Margin="10" Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBlock Text="Основные данные"
                                   Style="{StaticResource TitleText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Пациент:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,50,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientName, Mode=OneWay}"
                                 Margin="145,45,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Дата рождения:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,90,0,0"
                                   VerticalAlignment="Top"/>

                        <DatePicker SelectedDate="{Binding DateOfBirth, Mode=TwoWay}"
                                    Margin="145,85,10,0"
                                    Height="27"
                                    VerticalAlignment="Top"/>

                        <TextBlock Text="Группа крови:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,130,0,0"
                                   VerticalAlignment="Top"/>

                        <ComboBox ItemsSource="{Binding BloodGroups}"
                                  SelectedItem="{Binding SelectedBloodGroup, Mode=TwoWay}"
                                  Margin="145,125,10,0"
                                  Height="27"
                                  VerticalAlignment="Top">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ValueText}">
                                        <Run Text="{Binding Name}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RhFactor}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <CheckBox Content="Инвалидность"
                                  IsChecked="{Binding Disability, Mode=TwoWay}"
                                  Margin="145,170,10,0"
                                  VerticalAlignment="Top"/>

                        <Button Content="Сохранить карту"
                                Width="130"
                                Height="28"
                                HorizontalAlignment="Center"
                                Margin="0,215,0,0"
                                VerticalAlignment="Top"
                                Command="{Binding SaveMedCardCommand}"/>
                    </Grid>

                    <Border Grid.Column="1"
                            Style="{StaticResource VerticalSeparator}"
                            HorizontalAlignment="Center"
                            Height="620"
                            VerticalAlignment="Center"/>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Аллергии пациента"
                                           Style="{StaticResource TitleText}"
                                           HorizontalAlignment="Left"
                                           Margin="0,5,0,8"/>

                                <ListView ItemsSource="{Binding PatientAllergies}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Название"
                                                            DisplayMemberBinding="{Binding Name}"
                                                            Width="180"/>

                                            <GridViewColumn Header="Код"
                                                            DisplayMemberBinding="{Binding Code}"
                                                            Width="80"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="15,30,0,0">
                                <TextBlock Text="Добавить аллергию:"
                                           Style="{StaticResource LabelText}"/>

                                <ComboBox ItemsSource="{Binding AllAllergies}"
                                          SelectedItem="{Binding SelectedAllergy, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          Height="27"
                                          Margin="0,5,0,8"/>

                                <Button Content="Добавить"
                                        Width="100"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AddAllergyCommand}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Хронические заболевания"
                                           Style="{StaticResource TitleText}"
                                           HorizontalAlignment="Left"
                                           Margin="0,5,0,8"/>

                                <ListView ItemsSource="{Binding PatientChronicDiseases}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Название"
                                                            DisplayMemberBinding="{Binding Name}"
                                                            Width="180"/>

                                            <GridViewColumn Header="Код"
                                                            DisplayMemberBinding="{Binding Code}"
                                                            Width="80"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="15,30,0,0">
                                <TextBlock Text="Добавить заболевание:"
                                           Style="{StaticResource LabelText}"/>

                                <ComboBox ItemsSource="{Binding AllChronicDiseases}"
                                          SelectedItem="{Binding SelectedChronicDisease, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          Height="27"
                                          Margin="0,5,0,8"/>

                                <Button Content="Добавить"
                                        Width="100"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AddChronicDiseaseCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Прием и назначения">
                <Grid Margin="10" Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBlock Text="Результаты приема"
                                   Style="{StaticResource TitleText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Пациент:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,50,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedPatientName, Mode=OneWay}"
                                 Margin="120,45,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Результат:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,90,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding VisitResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="10,120,10,0"
                                 Height="250"
                                 VerticalAlignment="Top"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Button Content="Создать историю посещения"
                                Width="190"
                                Height="28"
                                HorizontalAlignment="Center"
                                Margin="0,390,0,0"
                                VerticalAlignment="Top"
                                Command="{Binding CreateVisitHistoryCommand}"/>
                    </Grid>

                    <Border Grid.Column="1"
                            Style="{StaticResource VerticalSeparator}"
                            HorizontalAlignment="Center"
                            Height="620"
                            VerticalAlignment="Center"/>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Назначить анализ"
                                           Style="{StaticResource TitleText}"
                                           HorizontalAlignment="Left"
                                           Margin="0,5,0,8"/>

                                <TextBlock Text="Анализ:"
                                           Style="{StaticResource LabelText}"/>

                                <ComboBox ItemsSource="{Binding Analyses}"
                                          SelectedItem="{Binding SelectedAnalysis, Mode=TwoWay}"
                                          DisplayMemberPath="AnalysisName"
                                          Height="27"
                                          Margin="0,5,0,8"/>

                                <TextBlock Text="Результат / комментарий:"
                                           Style="{StaticResource LabelText}"/>

                                <TextBox Text="{Binding AnalysisResult, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="55"
                                         Margin="0,5,0,8"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"/>

                                <Button Content="Назначить анализ"
                                        Width="130"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AddAnalysisCommand}"/>

                                <Button Content="Удалить назначение"
                                        Width="140"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        Command="{Binding DeleteAnalysisCommand}"/>
                            </StackPanel>

                            <ListView Grid.Column="1"
                                      Margin="15,30,0,0"
                                      ItemsSource="{Binding AnalysisHistories}"
                                      SelectedItem="{Binding SelectedAnalysisHistory, Mode=TwoWay}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Анализ"
                                                        DisplayMemberBinding="{Binding Analysis.AnalysisName}"
                                                        Width="160"/>

                                        <GridViewColumn Header="Результат"
                                                        DisplayMemberBinding="{Binding Result}"
                                                        Width="170"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Назначить препарат"
                                           Style="{StaticResource TitleText}"
                                           HorizontalAlignment="Left"
                                           Margin="0,5,0,8"/>

                                <TextBlock Text="Препарат:"
                                           Style="{StaticResource LabelText}"/>

                                <ComboBox ItemsSource="{Binding Recipes}"
                                          SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                                          DisplayMemberPath="Description"
                                          Height="27"
                                          Margin="0,5,0,8"/>

                                <TextBlock Text="Дозировка:"
                                           Style="{StaticResource LabelText}"/>

                                <TextBox Text="{Binding RecipeDosage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="27"
                                         Margin="0,5,0,8"/>

                                <TextBlock Text="Длительность:"
                                           Style="{StaticResource LabelText}"/>

                                <TextBox Text="{Binding RecipeDuration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="27"
                                         Margin="0,5,0,8"/>

                                <Button Content="Назначить препарат"
                                        Width="145"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AddRecipeCommand}"/>

                                <Button Content="Удалить назначение"
                                        Width="140"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        Command="{Binding DeleteRecipeCommand}"/>
                            </StackPanel>

                            <ListView Grid.Column="1"
                                      Margin="15,30,0,0"
                                      ItemsSource="{Binding RecipeHistories}"
                                      SelectedItem="{Binding SelectedRecipeHistory, Mode=TwoWay}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Препарат"
                                                        DisplayMemberBinding="{Binding Recipe.Description}"
                                                        Width="150"/>

                                        <GridViewColumn Header="Дозировка"
                                                        DisplayMemberBinding="{Binding Dosage}"
                                                        Width="100"/>

                                        <GridViewColumn Header="Длительность"
                                                        DisplayMemberBinding="{Binding Duration}"
                                                        Width="100"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="История пациента">
                <Grid Margin="10" Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="История посещений"
                                   Style="{StaticResource TitleText}"
                                   HorizontalAlignment="Left"
                                   Margin="0,5,0,8"/>

                        <ListView ItemsSource="{Binding VisitHistories}"
                                  SelectedItem="{Binding SelectedVisitHistory, Mode=TwoWay}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID"
                                                    DisplayMemberBinding="{Binding Id}"
                                                    Width="45"/>

                                    <GridViewColumn Header="Дата"
                                                    DisplayMemberBinding="{Binding VisitDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                    Width="100"/>

                                    <GridViewColumn Header="Услуга"
                                                    DisplayMemberBinding="{Binding MedService.ServiceName}"
                                                    Width="130"/>

                                    <GridViewColumn Header="Результат"
                                                    DisplayMemberBinding="{Binding VisitResults}"
                                                    Width="140"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource VerticalSeparator}"
                            HorizontalAlignment="Center"
                            Height="620"
                            VerticalAlignment="Center"/>

                    <Grid Grid.Column="2">
                        <TextBlock Text="Данные выбранного посещения"
                                   Style="{StaticResource TitleText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Дата:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,50,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedVisitDate, Mode=OneWay}"
                                 Margin="140,45,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Время:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,90,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedVisitTime, Mode=OneWay}"
                                 Margin="140,85,10,0"
                                 Height="27"
                                 VerticalAlignment="Top"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Результат:"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,130,0,0"
                                   VerticalAlignment="Top"/>

                        <TextBox Text="{Binding SelectedVisitResults, Mode=OneWay}"
                                 Margin="10,160,10,0"
                                 Height="120"
                                 VerticalAlignment="Top"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Назначенные анализы"
                                   Style="{StaticResource TitleText}"
                                   FontSize="14"
                                   HorizontalAlignment="Left"
                                   Margin="10,300,0,0"
                                   VerticalAlignment="Top"/>

                        <ListView ItemsSource="{Binding AnalysisHistories}"
                                  SelectedItem="{Binding SelectedAnalysisHistory, Mode=TwoWay}"
                                  Margin="10,330,10,0"
                                  Height="100"
                                  VerticalAlignment="Top">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Анализ"
                                                    DisplayMemberBinding="{Binding Analysis.AnalysisName}"
                                                    Width="170"/>

                                    <GridViewColumn Header="Результат"
                                                    DisplayMemberBinding="{Binding Result}"
                                                    Width="170"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <TextBlock Text="Назначенные препараты"
                                   Style="{StaticResource TitleText}"
                                   FontSize="14"
                                   HorizontalAlignment="Left"
                                   Margin="10,445,0,0"
                                   VerticalAlignment="Top"/>

                        <ListView ItemsSource="{Binding RecipeHistories}"
                                  SelectedItem="{Binding SelectedRecipeHistory, Mode=TwoWay}"
                                  Margin="10,475,10,0"
                                  Height="100"
                                  VerticalAlignment="Top">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Препарат"
                                                    DisplayMemberBinding="{Binding Recipe.Description}"
                                                    Width="160"/>

                                    <GridViewColumn Header="Дозировка"
                                                    DisplayMemberBinding="{Binding Dosage}"
                                                    Width="90"/>

                                    <GridViewColumn Header="Длительность"
                                                    DisplayMemberBinding="{Binding Duration}"
                                                    Width="100"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>