<Window x:Class="Poliklininka.PatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Poliklininka"
        mc:Ignorable="d"
        Title="PatientWindow" Height="467" Width="800">
    <Grid>
        <TabControl  HorizontalAlignment="Center" Height="Auto" VerticalAlignment="Top" Width="800">
            <TabItem  Name="TabАнкета" Header="Анкета" Margin="-2,-2,-2,0">
                <Grid Background="#FFE5E5E5"/>

            </TabItem>
            <TabItem Name="TabМедкарта" Header="Медкарта">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem  Name="TabИстория" Header="История посещений">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Name="TabЗаписи" Header="Мои записи">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
        </TabControl>
        <Grid HorizontalAlignment="Center" Height="389" Margin="0,35,0,0" VerticalAlignment="Top" Width="780">
            <TextBlock Name ="FIO" HorizontalAlignment="Left" Height="18" Margin="66,190,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="86" RenderTransformOrigin="0.457,0.579"><Run Language="ru-ru" Text="Полное имя"/></TextBlock>
            <TextBlock  Name ="number" HorizontalAlignment="Left" Height="18" Margin="66,234,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="88"><Run Language="ru-ru" Text="Телефон"/></TextBlock>
            <TextBlock  Name ="adrec" HorizontalAlignment="Left" Height="18" Margin="66,275,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="87"><Run Language="ru-ru" Text="Адрес"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Height="18" Margin="65,311,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="87"><Run Language="ru-ru" Text="Полис ОМС"/></TextBlock>
            <TextBlock  Name ="FIO_1" HorizontalAlignment="Left" Height="18" Margin="215,194,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175" Text="{Binding FullName}"/>
            <TextBlock   Name ="polis" HorizontalAlignment="Left" Height="18" Margin="215,311,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175" Text="{Binding InsurancePolicy}"/>
            <TextBlock  x:Name ="phone" HorizontalAlignment="Left" Height="18" Margin="215,230,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175" Text="{Binding PhoneNumber}"/>
            <TextBlock  x:Name ="adress" HorizontalAlignment="Left" Height="18" Margin="215,275,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175" Text="{Binding Address}"/>
            <Button Content="Редактировать" HorizontalAlignment="Left" Height="27" Margin="179,352,0,0" VerticalAlignment="Top" Width="105" Command="{Binding OpenRedAnketaCommand}"/>
            <Image Name ="Photo_Prof" HorizontalAlignment="Left" Height="150
                   " Margin="66,18,0,0" VerticalAlignment="Top" Width="150" Source="{Binding Photo}"/>
        </Grid>

    </Grid>
</Window>
