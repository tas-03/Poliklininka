<Window x:Class="Poliklininka.Login_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Poliklininka"
        mc:Ignorable="d"
        Title="Login_Window" Height="250" Width="392">
    <Grid>
        <TextBox Name ="login"  HorizontalAlignment="Left" Height="22"  TextWrapping="Wrap" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="242" Margin="96,58,0,0"/>
        <TextBox Name ="parol" HorizontalAlignment="Left" Height="22"  TextWrapping="Wrap" Text="{Binding Parol, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="242" Margin="96,90,0,0"/>
        <Label Content="Авторизуйтесь!" HorizontalAlignment="Center" Height="32" Margin="0,10,0,0" VerticalAlignment="Top" Width="94"/>
        <Label Content="Логин" HorizontalAlignment="Left" Height="32" Margin="46,56,0,0" VerticalAlignment="Top" Width="45"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Height="32" Margin="46,85,0,0" VerticalAlignment="Top" Width="55"/>
        <Button Content="Войти" HorizontalAlignment="Left" Height="27" Margin="125,136,0,0" VerticalAlignment="Top" Width="156" Command="{Binding AuthCommand}"/>

    </Grid>
</Window>
