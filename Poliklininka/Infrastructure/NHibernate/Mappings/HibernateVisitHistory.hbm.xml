<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="Poliklininka"
                   namespace="Poliklininka.Infrastructure.NHibernate.Models">

	<class name="HibernateVisitHistory" table="visit_histories" lazy="false">
		<id name="Id" column="id">
			<generator class="identity" />
		</id>

		<property name="AppointmentId" column="appointment_id" not-null="true" />
		<property name="PatientId" column="patient_id" not-null="true" />
		<property name="MedServiceId" column="med_service_id" not-null="true" />

		<property name="VisitDate"
				  column="visit_date"
				  type="Date"
				  not-null="true" />

		<property name="VisitTime"
				  column="visit_time"
				  type="TimeAsTimeSpan"
				  not-null="true" />

		<property name="VisitResults" column="visit_results" not-null="true" />

		<many-to-one name="Appointment"
					 class="HibernateAppointment"
					 column="appointment_id"
					 insert="false"
					 update="false"
					 lazy="false" />

		<many-to-one name="Patient"
					 class="HibernatePatient"
					 column="patient_id"
					 insert="false"
					 update="false"
					 lazy="false" />

		<many-to-one name="MedService"
					 class="HibernateMedService"
					 column="med_service_id"
					 insert="false"
					 update="false"
					 lazy="false" />

		<bag name="AnalysisHistories" inverse="true" cascade="none" lazy="false">
			<key column="visit_history_id" />
			<one-to-many class="HibernateAnalysisHistory" />
		</bag>

		<bag name="RecipeHistories" inverse="true" cascade="none" lazy="false">
			<key column="visit_history_id" />
			<one-to-many class="HibernateRecipeHistory" />
		</bag>

	</class>

</hibernate-mapping>