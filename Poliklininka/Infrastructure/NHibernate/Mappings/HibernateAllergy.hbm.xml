<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="Poliklininka"
                   namespace="Poliklininka.Infrastructure.NHibernate.Models">

	<class name="HibernateAllergy" table="allergies" lazy="false">
		<id name="Id" column="id">
			<generator class="identity" />
		</id>

		<property name="Name" column="name" not-null="true" />
		<property name="Code" column="code" not-null="true" />

		<bag name="MedCards"
			 table="allergy_patient"
			 inverse="true"
			 cascade="none"
			 lazy="true">
			<key column="allergy_id" />
			<many-to-many class="HibernateMedCard" column="medcard_id" />
		</bag>

	</class>

</hibernate-mapping>