<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="Poliklininka"
                   namespace="Poliklininka.Infrastructure.NHibernate.Models">

	<class name="HibernateUser" table="users" lazy="false">
		<id name="Id" column="id">
			<generator class="identity" />
		</id>

		<property name="Login" column="login" not-null="true" />
		<property name="Password" column="password" not-null="true" />
		<property name="Full_Name" column="full_name" not-null="true" />
		<property name="Role" column="role" not-null="true" />
		<property name="Discriminator" column="discriminator" not-null="false" />
	</class>

</hibernate-mapping>