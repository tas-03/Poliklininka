<Window x:Class="Poliklininka.New_User"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Poliklininka"
        mc:Ignorable="d"
        Title="New_User" Height="500" Width="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Логин*" HorizontalAlignment="Left" Height="28" Margin="41,131,0,0" VerticalAlignment="Top" Width="119"/>
        <Label Content="Пароль*" HorizontalAlignment="Left" Height="28" Margin="41,159,0,0" VerticalAlignment="Top" Width="119"/>
        <Label Content="ФИО*" HorizontalAlignment="Left" Height="28" Margin="41,192,0,0" VerticalAlignment="Top" Width="119"/>
        <Label Content="Роль*" HorizontalAlignment="Left" Height="28" Margin="41,98,0,0" VerticalAlignment="Top" Width="119"/>
        <ComboBox Name ="Role" HorizontalAlignment="Left" Height="28" Margin="144,96,0,0" VerticalAlignment="Top" Width="149" SelectionChanged="Role_SelectionChanged">
            <ComboBoxItem Content="Админ"/>
            <ComboBoxItem Content="Доктор"/>
            <ComboBoxItem Content="Пациент"/>
        </ComboBox>
        <TextBox Name ="login" HorizontalAlignment="Left" Height="23" Margin="144,131,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149"/>
        <TextBox Name ="password" HorizontalAlignment="Left" Height="23" Margin="144,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149"/>
        <TextBox Name ="fio" HorizontalAlignment="Left" Height="22" Margin="144,195,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149"/>
        <Label Content="Заполните поля!" HorizontalAlignment="Center" Height="36" Margin="0,29,0,0" VerticalAlignment="Top" Width="368"/>
        <Grid x:Name="DoctorPanel"  Visibility="Collapsed" HorizontalAlignment="Left" Height="115" Margin="41,240,0,0" VerticalAlignment="Top" Width="252">
            <Label Content="Специализация" HorizontalAlignment="Left" Height="29" Margin="0,10,0,0" VerticalAlignment="Top" Width="100"/>
            <Label Content="Кабинет" HorizontalAlignment="Left" Height="27" VerticalAlignment="Center" Width="100"/>
            <ComboBox Name ="Spec"  HorizontalAlignment="Left" Height="29" Margin="105,10,0,0" VerticalAlignment="Top" Width="147">
                <ComboBoxItem Content="Терапевт"/>
                <ComboBoxItem Content="Хирург"/>
                <ComboBoxItem Content="Лор"/>
            </ComboBox>    
            <TextBox Name ="Kabinet"  HorizontalAlignment="Left" Margin="105,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="147" Height="27" />
        </Grid>
        <Grid Name="Patient" Visibility="Collapsed" HorizontalAlignment="Left" Height="105" Margin="41,265,0,0" VerticalAlignment="Top" Width="252">
            <Label Content="Номер тел." HorizontalAlignment="Left" Height="27" VerticalAlignment="Top" Width="92"/>
            <Label Content="Полис ОМС" HorizontalAlignment="Left" Height="25" Margin="0,32,0,0" VerticalAlignment="Top" Width="78"/>
            <Label Content="Адрес" HorizontalAlignment="Left" Height="28" Margin="0,62,0,0" VerticalAlignment="Top" Width="78" RenderTransformOrigin="0.474,0.323"/>
            <TextBox Name ="Phone" HorizontalAlignment="Left" Height="27" Margin="106,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="146" />
            <TextBox Name ="Polic" HorizontalAlignment="Left" Height="25" Margin="106,32,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="146"/>
            <TextBox Name ="Adress" HorizontalAlignment="Left" Height="28" Margin="106,62,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="146"/>
        </Grid>
        <Button Content="Сохранить" HorizontalAlignment="Center" Height="29" Margin="0,415,0,0" VerticalAlignment="Top" Width="298" Click="Button_Click"/>

    </Grid>
</Window>
