<Application x:Class="Poliklininka.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Poliklininka">

    <Application.Resources>

        <!-- Основной фон Grid -->
        <Style x:Key="MainGridStyle" TargetType="Grid">
            <Setter Property="Background" Value="#FFE5E5E5"/>
        </Style>

        <!-- Заголовки -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#Strogo"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Подзаголовки (Полное имя, Телефон и тд) -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#Strogo"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#888780"/>
        </Style>

        <!-- Подсказки / служебный текст -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888780"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Текст из БД -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
        </Style>

        <Style x:Key="ValueTextbox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
        </Style>

        <!-- Вертикальная линия-разделитель -->
        <Style x:Key="VerticalSeparator" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Background" Value="#BDBDBD"/>
        </Style>

        <!-- Горизонтальная линия-разделитель -->
        <Style x:Key="UnderlineBorder" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#BDBDBD"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontFamily" Value="/Poliklininka;component/Fonts/#ProggyVector"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2C2C2A"/>
        </Style>

    </Application.Resources>
</Application>